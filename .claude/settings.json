{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write.*\\.env",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Arquivos .env nao devem ser editados diretamente. Use git para modificar.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write.*backend.*\\.py$",
        "hooks": [
          {
            "type": "command",
            "command": "cd ../backend && .venv/Scripts/python -m ruff check --fix \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit|Write.*backend.*test.*\\.py$",
        "hooks": [
          {
            "type": "command",
            "command": "cd ../backend && .venv/Scripts/python -m pytest \"$CLAUDE_FILE_PATH\" -v"
          }
        ]
      },
      {
        "matcher": "Write.*backend.*\\.py$",
        "hooks": [
          {
            "type": "command",
            "command": "cd ../backend && .venv/Scripts/python -m bandit -r \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit|Write.*(src|test|electron).*\\.(ts|tsx)$",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit|Write.*(src|test|electron).*\\.(ts|tsx)$",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Write.*(src|electron).*\\.(ts|tsx)$",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit \"$CLAUDE_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Edit|Write.*test.*\\.(ts|tsx)$",
        "hooks": [
          {
            "type": "command",
            "command": "npx vitest run \"$CLAUDE_FILE_PATH\""
          }
        ]
      }
    ]
  }
}
